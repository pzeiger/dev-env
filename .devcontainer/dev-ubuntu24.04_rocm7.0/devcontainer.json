// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
{
    "name": "Dev Ubuntu 24.04 ROCm 7.0",

    "build": {
        "dockerfile": "Dockerfile"
    },

    "workspaceFolder": "/workspaces",
    "remoteUser": "ubuntu",
    "updateRemoteUserUID": true,

    "mounts": [
      "source=${localWorkspaceFolder}/../code/abTEM,target=/workspaces/code/abTEM,type=bind",
      "source=${localWorkspaceFolder}/../code/gpaw,target=/workspaces/code/gpaw,type=bind",
      "source=${localWorkspaceFolder}/../code/PySlice,target=/workspaces/code/PySlice,type=bind",
      "source=${localWorkspaceFolder}/../code/gpaw-weaver,target=/workspaces/code/gpaw-weaver,type=bind",
      "source=${localWorkspaceFolder}/../code/EELSfornax,target=/workspaces/code/EELSfornax,type=bind",
      "source=${localWorkspaceFolder}/../projects,target=/workspaces/projects,type=bind",
      "source=${localWorkspaceFolder}/../run,target=/workspaces/run,type=bind"
    ],
    "postCreateCommand": "GPAW_CONFIG='${containerWorkspaceFolder}/dev-env/.devcontainer/dev-ubuntu24.04_rocm7.0/siteconfig.py' bash /workspaces/dev-env/setup.sh && uv pip install --no-cache pypdf",
    "postStartCommand": "cd /workspaces/run && gpaw test && gpaw -P 4 test && cd ${containerWorkspaceFolder} && nohup bash -c 'jupyter notebook --ip=0.0.0.0 --port=8888 --allow-root --NotebookApp.token='' --no-browser > /home/ubuntu/nohup.out &'",

    "forwardPorts": [
        8888
    ],

    // Configure tool-specific properties.
    "customizations": {
        // Configure propertie s specific to VS Code.
        "vscode": {
            "settings": {
                "terminal.integrated.cwd": "/workspaces"
            },
            // Add the IDs of extensions you want installed when the container is created.
            "extensions": [
		"ms-python.python",
		"charliermarsh.ruff",
		"ms-toolsai.jupyter",
		"tamasfe.even-better-toml",
		"anthropic.claude-code"
            ]
        }
    },

    "runArgs": [
	"--cap-add=SYS_PTRACE",
        "--security-opt",
        "seccomp=unconfined",
        "--device=/dev/kfd",
        "--device=/dev/dri",
        "--device=/dev/fuse",
        "--group-add=video",
        "--ipc=host",
        "--shm-size",
        "8G"
    ],

    "containerEnv": {
        "PYTHONUNBUFFERED": "1",
        "PIP_DISABLE_PIP_VERSION_CHECK": "1",
        "CLAUDE_CODE_OAUTH_TOKEN": "${localEnv:CLAUDE_CODE_OAUTH_TOKEN}",
        "ANTHROPIC_OAUTH_TOKEN": "${localEnv:CLAUDE_CODE_OAUTH_TOKEN}",
        "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
        "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
        "CLAUDE_CONFIG_DIR": "/workspaces/dev-env/.claude",
        "GPAW_NEW": "0",
        "GPAW_USE_GPUS": "0",
        "XLA_PYTHON_CLIENT_PREALLOCATE": "false",
        "JAX_COMPILATION_CACHE_DIR": "/workspaces/run/.jax_cache",
        "LLVM_PATH": "/opt/rocm/llvm"
    }

}
