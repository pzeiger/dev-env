// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
{
    "name": "Dev Ubuntu 24.04 ROCm 7.0",

    "build": {
        "dockerfile": "Dockerfile"
    },

    "workspaceFolder": "/workspaces/dev-env",
//    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "remoteUser": "ubuntu",
    "updateRemoteUserUID": true,

    "mounts": [
      "source=${localWorkspaceFolder}/../abTEM,target=/workspaces/abTEM,type=bind",
      "source=${localWorkspaceFolder}/../gpaw,target=/workspaces/gpaw,type=bind",
      "source=${localWorkspaceFolder}/../gpaw-weaver,target=/workspaces/gpaw-weaver,type=bind",
      "source=${localWorkspaceFolder}/../Yoshiax,target=/workspaces/Yoshiax,type=bind",
      "source=${localWorkspaceFolder}/../projects,target=/workspaces/projects,type=bind"
    ],
    "postCreateCommand": "bash /workspaces/dev-env/setup.sh && pip install --no-cache-dir pypdf",
//    "postCreateCommand": "uv pip install --no-cache-dir -e . && uv pip install --no-cache-dir xarray jupyterlab",
//    "postStartCommand": "nohup bash -c 'jupyter notebook --ip=0.0.0.0 --port=8888 --allow-root --NotebookApp.token='' --no-browser > nohup.out &'",

//    "forwardPorts": [
//        8888
//    ],

    // Configure tool-specific properties.
    "customizations": {
        // Configure propertie s specific to VS Code.
        "vscode": {
            "settings": {
                "terminal.integrated.cwd": "/workspaces"
            },
            // Add the IDs of extensions you want installed when the container is created.
            "extensions": [
		"ms-python.python",
		"charliermarsh.ruff",
		"ms-toolsai.jupyter",
		"tamasfe.even-better-toml",
		"anthropic.claude-code"
            ]
        }
    },

    "runArgs": [
	"--cap-add=SYS_PTRACE",
        "--security-opt",
        "seccomp=unconfined",
        "--device=/dev/kfd",
        "--device=/dev/dri",
        "--group-add=video",
        "--ipc=host",
        "--shm-size",
        "8G"
    ],

    "containerEnv": {
        "PYTHONUNBUFFERED": "1",
        "PIP_DISABLE_PIP_VERSION_CHECK": "1",
        "CLAUDE_CODE_OAUTH_TOKEN": "${localEnv:CLAUDE_CODE_OAUTH_TOKEN}",
        "ANTHROPIC_OAUTH_TOKEN": "${localEnv:CLAUDE_CODE_OAUTH_TOKEN}",
        "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
        "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
        "CLAUDE_CONFIG_DIR": "/workspaces/dev-env/.claude",
        "GPAW_NEW": "0",
        "GPAW_USE_GPUS": "0",
        "CLAUDE_CODE_OAUTH_TOKEN": "${localEnv:CLAUDE_CODE_OAUTH_TOKEN}",
        "ANTHROPIC_OAUTH_TOKEN": "${localEnv:ANTHROPIC_OAUTH_TOKEN}"
    }

}
